<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="16dp">

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: READY"
        android:textColor="#00FF00"
        android:textSize="20sp"
        android:gravity="center"
        android:padding="10dp" />

    <TextView
        android:id="@+id/rootText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ROOT: CHECKING..."
        android:textColor="#FF0000"
        android:textSize="16sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/ramText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Free RAM: 0 MB"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/pingText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ping: 0 ms"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:gravity="center"
        android:paddingBottom="20dp" />

    <Button
        android:id="@+id/gameModeBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="START GAME MODE"
        android:background="#FF0000"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/bubbleBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SHOW BUBBLE"
        android:layout_marginTop="10dp" />

</LinearLayout>
