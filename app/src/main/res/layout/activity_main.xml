<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/background">

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/accent"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gaming Performance Booster"
        android:textSize="14sp"
        android:textColor="@color/textSecondary"
        android:layout_marginBottom="40dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bubble Overlay: INACTIVE"
        android:textSize="16sp"
        android:textColor="@color/textPrimary"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnStartBubble"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Start Bubble Overlay"
        android:textColor="@color/white"
        android:backgroundTint="@color/accent"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnStopBubble"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Stop Bubble Overlay"
        android:textColor="@color/white"
        android:backgroundTint="@color/danger"
        android:enabled="false"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnKillProcesses"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Kill Background Processes"
        android:textColor="@color/white"
        android:backgroundTint="@color/textSecondary"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap the bubble to return here. Drag to reposition."
        android:textSize="12sp"
        android:textColor="@color/textSecondary"
        android:gravity="center" />

</LinearLayout>
