<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="250dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC000000"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔥 GAME BOOSTER PRO"
        android:textColor="#00FF00"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="8dp"/>

    <TextView
        android:id="@+id/tvAimbot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎯 Aimbot: OFF"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:padding="8dp"
        android:background="#33FFFFFF"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tvHeadshot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔫 Headshot: OFF"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:padding="8dp"
        android:background="#33FFFFFF"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/tvNoRecoil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💥 No Recoil: OFF"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:padding="8dp"
        android:background="#33FFFFFF"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/tvWallhack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="👁️ Wallhack: OFF"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:padding="8dp"
        android:background="#33FFFFFF"
        android:layout_marginTop="4dp"/>

    <Button
        android:id="@+id/btnUnlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔓 UNLOCK ALL"
        android:textColor="#000000"
        android:background="#FFD700"
        android:layout_marginTop="12dp"/>

    <Button
        android:id="@+id/btnClose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="❌ CLOSE"
        android:textColor="#FFFFFF"
        android:background="#FF0000"
        android:layout_marginTop="4dp"/>

</LinearLayout>
